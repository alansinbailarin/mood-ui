', ⏎                 page: () => import('./pages/layout/PageHeaderPage.vue'), ⏎             }, ⏎             { ⏎                 id: 'container', ⏎                 label: 'Container', ⏎                 page: () => import('./pages/layout/ContainerPage.vue'), ⏎             }, ⏎             { ⏎                 id: 'divider', ⏎                 label: 'Divider', ⏎                 page: () => import('./pages/layout/DividerPage.vue'), ⏎                 badge: 'New', ⏎             }, ⏎             { ⏎                 id: 'stack', ⏎                 label: 'Stack', ⏎                 page: () => import('./pages/layout/StackPage.vue'), ⏎                 badge: 'New', ⏎             }, ⏎             { ⏎                 id: 'popover-panel', ⏎                 label: 'PopoverPanel', ⏎                 page: () => import('./pages/layout/PopoverPanelPage.vue'), ⏎             }, ⏎         ], ⏎     }, ⏎     { ⏎         id: 'navigation', ⏎         title: 'Navigation', ⏎         entries: [ ⏎             { ⏎                 id: 'tabs', ⏎                 label: 'Tabs', ⏎                 page: () => import('./pages/navigation/TabsPage.vue'), ⏎             }, ⏎             { ⏎                 id: 'breadcrumbs', ⏎                 label: 'Breadcrumbs', ⏎                 page: () => import('./pages/navigation/BreadcrumbsPage.vue'), ⏎                 badge: 'New', ⏎             }, ⏎             { ⏎                 id: 'dropdown-menu', ⏎                 label: 'DropdownMenu', ⏎                 page: () => import('./pages/navigation/DropdownMenuPage.vue'), ⏎                 badge: 'New', ⏎             }, ⏎             { ⏎                 id: 'pagination', ⏎                 label: 'Pagination', ⏎                 page: () => import('./pages/navigation/PaginationPage.vue'), ⏎                 badge: 'New', ⏎             }, ⏎         ], ⏎     }, ⏎ ]; ⏎  ⏎ /** Find an entry by id across all categories. */ ⏎ export function findEntry(id: string) { ⏎     for (const cat of showroomNav) { ⏎         const found = cat.entries.find((e) => e.id === id); ⏎         if (found) return found; ⏎     } ⏎     return undefined; ⏎ } ⏎ ``` ⏎  ⏎ --- ⏎  ⏎ ## Cierre del tutorial ⏎  ⏎ Con esto el tutorial cubre, en orden de dependencia y verbatim: ⏎  ⏎ - **Fase 1** · Bootstrap del proyecto, `package.json`, `vite.config.ts`, ⏎   `tsconfig*`, `vitest.config.ts`, `index.html`, `main.ts`. ⏎ - **Fase 2** · Tokens OKLCH y `style.css` con `@theme` / `@theme inline` ⏎   / `light-dark()`. ⏎ - **Fase 3** · `config/`: `ModoConfig`, `ModoLocale`, `palettes`, ⏎   `colorPrimitives`, `createModoUI`. ⏎ - **Fase 4** · Composables core: `useColorMode`, `useModoConfig` ⏎   (cascada de defaults), `useField`, `usePopover`, `useToast`, ⏎   `useConfirm`. ⏎ - **Fase 5** · `ModoProvider.vue` (cascada provider con herencia del ⏎   padre). ⏎ - **Fase 6** · Layout: `AppShell`, `Canvas`, `Container`, `Divider`, ⏎   `Stack`, `HStack`, `VStack`, `PageHeader`, `PopoverPanel`, `Sidebar*`, ⏎   `Topbar`. ⏎ - **Fase 7** · Data-display básico: `Card`, `Typography`. ⏎ - **Fase 8** · Forms primitivos: `Button`, `ButtonGroup`, `FormField`, ⏎   `Input`, `Textarea`, `PasswordInput`, `NumberInput`, `SearchInput`, ⏎   `Slider`, `RangeSlider`, `FileInput`. ⏎ - **Fase 9** · Forms de selección: `Select`, `MultiSelect`, `Combobox`, ⏎   `Checkbox`, `Radio` + `RadioGroup`, `Switch`. ⏎ - **Fase 10** · Feedback: `Badge`, `Banner`, `Chip`, `ConfirmDialog`, ⏎   `Drawer`, `EmptyState`, `Loader`, `Modal`, `ProgressBar`, `Skeleton`, ⏎   `Toast` + `ToastContainer`, `Tooltip`. ⏎ - **Fase 11** · Navigation + Shell: `Tabs`, `Breadcrumbs`, ⏎   `DropdownMenu`, `Pagination`. ⏎ - **Fase 12** · Avatar (`Avatar`, `AvatarGroup`) + Table (`Table`, ⏎   `TableColumn`, `TablePagination`) y todos sus composables. ⏎ - **Fase 13** · Calendar suite completa: 11 interfaces, 8 composables ⏎   específicos, `DateField` / `DateRangeField` / `DateTimeField` con ⏎   sus pickers, `Calendar` + `CalendarHeader` + `CalendarEventTooltip`, ⏎   `MonthView`, `AgendaView`, `WeekView`, `DayView` y `Scheduler`. ⏎ - **Fase 14** · Barrel `src/index.ts`, tests Vitest y showroom registry. ⏎  ⏎ ### Cómo construir y publicar ⏎  ⏎ ```bash ⏎ # Dev (showroom) ⏎ npm run dev ⏎  ⏎ # Type-check + build (lib mode) ⏎ npm run build ⏎  ⏎ # Tests ⏎ npm run test ⏎  ⏎ # Preview producción ⏎ npm run preview ⏎ ``` ⏎  ⏎ ### Cómo consumir desde otra app ⏎  ⏎ ```ts ⏎ // main.ts ⏎ import { createApp } from 'vue'; ⏎ import App from './App.vue'; ⏎ import 'modo-ui/dist/style.css'; ⏎  ⏎ createApp(App).mount('#app'); ⏎ ``` ⏎  ⏎ ```vue ⏎ <template> ⏎     <ModoProvider color="primary" radius="medium" theme="auto"> ⏎         <Button variant="filled" :loading="busy" @click="save"> ⏎             Guardar ⏎         </Button> ⏎     </ModoProvider> ⏎ </template> ⏎  ⏎ <script setup lang="ts"> ⏎ import { ref } from 'vue'; ⏎ import { ModoProvider, Button } from 'modo-ui'; ⏎ const busy = ref(false); ⏎ const save = () => { ⏎     busy.value = true; ⏎     setTimeout(() => (busy.value = false), 800); ⏎ }; ⏎ </script> ⏎ ``` ⏎  ⏎ ### Reglas de oro al añadir un componente ⏎  ⏎ 1. **Tokens, no colores hardcoded** (ver `MODO_UI_RULES.md` §2). ⏎ 2. **Contrato de props canónico** (`size: 'small' | 'medium' | 'large'`, ⏎    `variant`, `color`, `radius`, `disabled`, `loading`, `fullWidth`, ⏎    `icon`, `iconPosition`, `ariaLabel`). ⏎ 3. **Cascada de providers**: usa `useResolvedColor`, `useResolvedRadius`, ⏎    `useResolvedSize`, `useResolvedTheme`, `useResolvedHalo` en lugar ⏎    de defaults locales. ⏎ 4. **Halo pattern** para interactivos rellenos (ring-3 persistente + ⏎    transición de `--tw-ring-color`). ⏎ 5. **A11y**: focus-visible, ARIA roles, icon-only requiere `ariaLabel`. ⏎ 6. **Motion**: usa los tokens `duration-*` y `ease-*` y respeta ⏎    `prefers-reduced-motion`. ⏎ 7. **Exporta** desde `src/index.ts` y crea su `*Page.vue` en showroom. ⏎  ⏎ Fin del tutorial. La librería está documentada al 100% en orden de ⏎ dependencia y lista para reproducirse desde cero. ⏎