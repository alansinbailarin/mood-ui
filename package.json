{
  "name": "mood-ui-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm --filter mood-ui build",
    "build:showroom": "pnpm --filter showroom generate",
    "dev": "pnpm --filter showroom dev",
    "dev:lib": "pnpm --filter mood-ui dev",
    "test": "pnpm --filter mood-ui test",
    "test:watch": "pnpm --filter mood-ui test:watch",
    "lint:lib": "pnpm --filter mood-ui run lint",
    "publish:lib": "pnpm --filter mood-ui publish"
  },
  "devDependencies": {},
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "vue-demi"
    ],
    "overrides": {
      "h3": "1.15.11"
    }
  }
}
