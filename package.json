{
  "name": "mood-ui-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm --filter mood-ui build",
    "build:docs": "pnpm --filter docs generate",
    "dev": "pnpm --filter docs dev",
    "dev:lib": "pnpm --filter mood-ui dev",
    "test": "pnpm --filter mood-ui test",
    "test:watch": "pnpm --filter mood-ui test:watch",
    "lint:lib": "pnpm --filter mood-ui run lint",
    "publish:lib": "pnpm --filter mood-ui publish"
  },
  "devDependencies": {}
}
