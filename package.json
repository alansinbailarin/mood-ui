{
  "name": "mood-ui",
  "version": "0.1.0",
  "description": "Vue 3 component library with full theming, dark mode, palettes, calendar, scheduler, table and AppShell.",
  "type": "module",
  "license": "MIT",
  "author": "alansinbailarin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alansinbailarin/modo-components.git"
  },
  "homepage": "https://github.com/alansinbailarin/modo-components#readme",
  "bugs": {
    "url": "https://github.com/alansinbailarin/modo-components/issues"
  },
  "keywords": ["vue", "vue3", "components", "ui", "tailwindcss", "design-system", "modo"],
  "main": "./dist/mood-ui.cjs",
  "module": "./dist/mood-ui.mjs",
  "types": "./dist/index.d.ts",
  "style": "./dist/mood-ui.css",
  "sideEffects": ["**/*.css"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/mood-ui.mjs",
      "require": "./dist/mood-ui.cjs"
    },
    "./style.css": "./dist/mood-ui.css",
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "dev": "vite",
    "build": "BUILD_TARGET=lib vue-tsc -p tsconfig.lib.json --noEmit && BUILD_TARGET=lib vite build",
    "build:showroom": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@heroicons/vue": "^2.0.0",
    "gsap": "^3.0.0",
    "vue": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "gsap": { "optional": true },
    "@heroicons/vue": { "optional": true }
  },
  "dependencies": {},
  "devDependencies": {
    "@heroicons/vue": "^2.2.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/ui": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "gsap": "^3.15.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.5",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.7"
  }
}
