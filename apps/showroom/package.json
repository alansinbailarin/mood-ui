{
  "name": "showroom",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "build": "pnpm run llms && nuxt build",
    "dev": "nuxt dev",
    "generate": "pnpm run llms && NODE_OPTIONS=\"--max-old-space-size=8192\" nuxt generate",
    "preview": "nuxt preview",
