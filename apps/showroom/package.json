    "typecheck": "nuxt typecheck",
    "llms": "tsx scripts/generate-llms.ts"
  },
  "dependencies": {
    "@heroicons/vue": "^2.2.0",
    "gsap": "^3.15.0",
    "mood-ui": "workspace:*",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@nuxt/fonts": "^0.14.0",
    "@nuxtjs/i18n": "^10.4.0",
    "@nuxtjs/seo": "^5.3.1",
    "@tailwindcss/vite": "^4.2.4",
    "@takumi-rs/core": "2.0.0-beta.14",
    "@types/node": "^24.12.2",
    "nuxt": "^4.0.0",
    "shiki": "^1.29.2",
    "tailwindcss": "^4.2.4",
    "ts-morph": "^28.0.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vue-tsc": "^3.2.7"
  }
